# ── Plaid API ─────────────────────────────────────────────────────────────────
# ⚠️  You need a Plaid account before this works:
#   1. Sign up at https://dashboard.plaid.com (free)
#   2. Apply for Development access (1-3 business days)
#   3. Copy your Client ID and Development Secret from:
#      https://dashboard.plaid.com/developers/keys
#   4. Register http://localhost:5555/oauth-callback as an allowed redirect URI
#      in Plaid Dashboard → Settings → Allowed redirect URIs (for Fidelity OAuth)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=development

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (self-hosted via Docker Compose) ─────────────────────────────────
# Run `bash scripts/generate-keys.sh` from project root first, then copy values.
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=

# ── Email notifications (SendGrid) ────────────────────────────────────────────
# Optional — skip if you don't want email alerts
# Create a free account + verified sender at: https://app.sendgrid.com/
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_FROM_EMAIL=your-verified-sender@example.com
NOTIFICATION_EMAIL=you@example.com

# ── Slack notifications (optional) ────────────────────────────────────────────
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ── Pushover notifications (optional) ─────────────────────────────────────────
# https://pushover.net/
# PUSHOVER_USER_KEY=your_user_key
# PUSHOVER_APP_TOKEN=your_app_token
