# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.
#
# Self-hosted Supabase setup order:
#   1. bash scripts/generate-keys.sh     → creates .env.docker
#   2. bash scripts/generate-totp-secret.sh → prints TOTP_SECRET + SESSION_SECRET
#   3. docker compose up -d
#   4. bash scripts/init-db.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (self-hosted via Docker Compose) ─────────────────────────────
# Kong API gateway — do not change unless you change docker-compose.yml ports
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Anon key from .env.docker (copy the ANON_KEY value)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key from .env.docker (copy SERVICE_ROLE_KEY) — server-side only, bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=

# ── TOTP Authentication ────────────────────────────────────────────────────
# Run `bash scripts/generate-totp-secret.sh` to generate these.
# Scan the printed QR code with Google Authenticator ONCE during setup.
TOTP_SECRET=

# Random hex string — signs the session cookie. Generated by generate-totp-secret.sh.
SESSION_SECRET=
