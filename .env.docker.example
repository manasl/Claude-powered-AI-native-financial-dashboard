# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose secrets for self-hosted Supabase.
# Copy to .env.docker (gitignored) — DO NOT fill in this example file.
#
# Auto-generate all values by running:
#   bash scripts/generate-keys.sh
# ─────────────────────────────────────────────────────────────────────────────

# Postgres superuser password
POSTGRES_PASSWORD=

# JWT shared secret (used to sign ANON_KEY and SERVICE_ROLE_KEY)
JWT_SECRET=

# Supabase API keys (JWTs signed with JWT_SECRET)
# Paste into .env.local as NEXT_PUBLIC_SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY
ANON_KEY=
SERVICE_ROLE_KEY=

# PostgREST database connection string (authenticator role)
# Format: postgresql://authenticator:<POSTGRES_PASSWORD>@db:5432/postgres
PGRST_DB_URI=
PGRST_JWT_SECRET=

# Postgres Meta (for Studio) — same as POSTGRES_PASSWORD
PG_META_DB_PASSWORD=

# Studio (same values as above, different var names)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
